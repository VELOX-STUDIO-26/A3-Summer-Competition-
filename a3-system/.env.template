# A3 Learning System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Environment Settings
# ============================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info

# ============================================
# API Configuration
# ============================================
API_PORT=8000
API_HOST=0.0.0.0
FRONTEND_PORT=3000

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_USER=a3_user
DB_PASSWORD=a3_password
DB_NAME=a3_db
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://a3_user:a3_password@postgres:5432/a3_db

# ============================================
# Cache Configuration (Redis)
# ============================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# Vector Database (Weaviate)
# ============================================
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_GRPC_PORT=50051

# ============================================
# LLM Configuration
# ============================================
# At least one LLM key is required.

# Primary: Kimi / Moonshot AI (recommended for production)
# Get your API key at: https://platform.moonshot.cn
OPENROUTER_KIMI_API_KEY=your-kimi-key-here
OPENROUTER_KIMI_MODEL=kimi-k2.6
OPENROUTER_KIMI_BASE_URL=https://api.moonshot.cn

# Fallback: OpenRouter (free tier)
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# Optional: OpenAI (if you have credits)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# Optional: iFlytek Spark (for competition evaluation)
# SPARK_APP_ID=your-app-id
# SPARK_API_KEY=your-api-key
# SPARK_API_SECRET=your-api-secret

# ============================================
# TTS/Voice Configuration (Edge-TTS - Free)
# ============================================
# Edge-TTS requires no API key - uses Microsoft Edge voices
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural

# Optional: iFlytek TTS (for production quality)
# TTS_PROVIDER=iflytek
# IFLYTEK_TTS_APP_ID=your-app-id
# IFLYTEK_TTS_API_KEY=your-api-key

# ============================================
# Security Settings
# ============================================
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# pgAdmin (Optional - for database management)
# ============================================
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@a3.local
PGADMIN_PASSWORD=admin

# ============================================
# Chunking Settings for RAG
# ============================================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_CHUNK_SIZE=1000

# ============================================
# Path Planning Settings
# ============================================
MAX_PATH_NODES=25
PLANNING_TIMEOUT_MS=3000
PATH_CACHE_TTL_MINUTES=60

# ============================================
# Development Settings
# ============================================
RELOAD_ON_CHANGE=true
DEBUG_SHOW_TRACE=true
